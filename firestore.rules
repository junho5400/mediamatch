rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Library subcollections — owner only
      match /library/{mediaType} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        match /entries/{entryId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

      // AI report cache — owner only
      match /ai-report/{reportId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Media documents — authenticated users can read, only server writes
    match /media/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // Server-side only via Admin SDK
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
